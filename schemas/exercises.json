{
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "title": {
                "type": "string",
                "markdownDescription": "The _name_ of the exercise, e.g. `Drop Jump`."
            },
            "category": {
                "type": "string",
                "enum": [
                    "Functional Diagnostics",
                    "Mobilization & Activation",
                    "Neuromuscular Training",
                    "Jump Power",
                    "Running Drills"
                ],
                "markdownDescription": "Which block of the program this exercise belongs to. The template groups the manual by this."
            },
            "focus": {
                "type": "string",
                "markdownDescription": "The training emphasis shown in the first chip, e.g. `Functional diagnostics`, `Strength`, `Mobility`."
            },
            "equipment": {
                "type": "string",
                "markdownDescription": "What you need for the exercise, e.g. `None`, `Ball`, `Elastic resistance band`."
            },
            "photo": {
                "type": "string",
                "pattern": "^ex_[0-9]{2}\\.png$",
                "markdownDescription": "Filename of the demonstration photo in `static/img/exercises/`, e.g. `ex_08.png`."
            },
            "goal": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1,
                "markdownDescription": "One or more bullet points describing the _goal_ of the exercise."
            },
            "execution": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 1,
                "markdownDescription": "Step-by-step bullets for _how_ to perform the exercise."
            },
            "blocks": {
                "type": "array",
                "markdownDescription": "Extra labelled sections shown after Execution (Assessment / Notes / Variant).",
                "items": {
                    "type": "object",
                    "properties": {
                        "label": {
                            "type": "string",
                            "enum": ["Assessment", "Notes", "Variant"]
                        },
                        "items": {
                            "type": "array",
                            "items": { "type": "string" },
                            "minItems": 1
                        }
                    },
                    "required": ["label", "items"],
                    "additionalProperties": false
                }
            }
        },
        "required": [
            "title",
            "category",
            "focus",
            "equipment",
            "photo",
            "goal",
            "execution"
        ],
        "additionalProperties": false
    }
}
